<% content_for(:page_title, @form_definition.name) %>

<div class="mb-6">
  <%= link_to form_definitions_path, class: "inline-flex items-center text-sm text-text-muted hover:text-text" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Forms
  <% end %>
</div>

<div class="bg-bg-card border border-border rounded-lg p-6">
  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-text"><%= @form_definition.name %></h2>
      <p class="text-sm text-text-muted mt-1">slug: <%= @form_definition.slug %></p>
      <% if @form_definition.description.present? %>
        <p class="text-text mt-2"><%= @form_definition.description %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-3">
      <% case @form_definition.status %>
      <% when "draft" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-900/50 text-yellow-300 border border-yellow-700">Draft</span>
      <% when "published" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-success/10 text-success border border-success/30">Published</span>
      <% when "archived" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent text-text-muted border border-border">Archived</span>
      <% end %>
    </div>
  </div>

  <div class="flex items-center gap-3 mb-6">
    <% unless @form_definition.archived? %>
      <%= link_to "Edit", edit_form_definition_path(@form_definition.uuid), class: "inline-flex items-center px-4 py-2 bg-bg-input hover:bg-accent text-text rounded-lg text-sm font-medium transition-colors border border-border" %>
    <% end %>
    <% if @form_definition.draft? %>
      <%= button_to "Publish", publish_form_definition_path(@form_definition.uuid), method: :post, class: "inline-flex items-center px-4 py-2 bg-success hover:bg-success/80 text-primary-fg rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
    <% end %>
    <% if @form_definition.published? %>
      <%= button_to "Archive", archive_form_definition_path(@form_definition.uuid), method: :post, class: "inline-flex items-center px-4 py-2 bg-yellow-700 hover:bg-yellow-600 text-primary-fg rounded-lg text-sm font-medium transition-colors cursor-pointer", form: { data: { turbo_confirm: "Are you sure you want to archive this form?" } } %>
      <%= link_to "View Submissions", form_submissions_path(form_definition_id: @form_definition.id), class: "inline-flex items-center px-4 py-2 bg-bg-input hover:bg-accent text-text rounded-lg text-sm font-medium transition-colors border border-border" %>
    <% end %>
    <%= button_to "Delete", form_definition_path(@form_definition.uuid), method: :delete, class: "inline-flex items-center px-4 py-2 bg-destructive hover:bg-destructive/80 text-primary-fg rounded-lg text-sm font-medium transition-colors cursor-pointer", form: { data: { turbo_confirm: "Are you sure you want to delete this form?" } } %>
  </div>

  <div class="border-t border-border pt-6">
    <h3 class="text-lg font-semibold text-text mb-4">Form Fields (<%= @form_definition.field_definitions.size %>)</h3>

    <% if @form_definition.field_definitions.any? %>
      <div class="space-y-3">
        <% @form_definition.field_definitions.each_with_index do |field, index| %>
          <div class="bg-bg border border-border rounded-lg p-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="text-xs font-mono text-text-muted">#<%= index + 1 %></span>
                <span class="text-sm font-medium text-text"><%= field["label"] || field["name"] %></span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-accent text-text-muted"><%= field["type"] %></span>
              </div>
              <div class="flex items-center gap-2 text-xs text-text-muted">
                <span>name: <%= field["name"] %></span>
                <% if field.dig("validations", "required") %>
                  <span class="text-destructive">required</span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-text-muted text-sm">No fields defined yet. <%= link_to "Edit this form", edit_form_definition_path(@form_definition.uuid), class: "text-primary hover:underline" %> to add fields.</p>
    <% end %>
  </div>

  <dl class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6 border-t border-border pt-6">
    <div>
      <dt class="text-sm font-medium text-text-muted">Created</dt>
      <dd class="mt-1 text-text-muted text-sm"><%= @form_definition.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-text-muted">Updated</dt>
      <dd class="mt-1 text-text-muted text-sm"><%= @form_definition.updated_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
    </div>
  </dl>
</div>
