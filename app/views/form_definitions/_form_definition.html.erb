<tr id="<%= dom_id(form_definition) %>" class="hover:bg-accent">
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= link_to form_definition.name, form_definition_path(form_definition.uuid), class: "text-primary hover:underline" %>
    <p class="text-xs text-text-muted mt-0.5"><%= form_definition.slug %></p>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm">
    <% case form_definition.status %>
    <% when "draft" %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-900/50 text-yellow-300 border border-yellow-700">Draft</span>
    <% when "published" %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-success/10 text-success border border-success/30">Published</span>
    <% when "archived" %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent text-text-muted border border-border">Archived</span>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= form_definition.field_definitions.size %> fields
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= form_definition.form_submissions.count %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text-muted">
    <%= form_definition.created_at.strftime("%b %d, %Y") %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to "Edit", edit_form_definition_path(form_definition.uuid), class: "text-primary hover:underline mr-3" %>
    <%= button_to "Delete", form_definition_path(form_definition.uuid), method: :delete, class: "text-destructive hover:underline", form: { data: { turbo_confirm: "Are you sure you want to delete this form?" } } %>
  </td>
</tr>
