<tr id="<%= dom_id(form_definition) %>" class="hover:bg-gray-750">
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-100">
    <%= link_to form_definition.name, form_definition_path(form_definition.uuid), class: "text-red-400 hover:text-red-300" %>
    <p class="text-xs text-gray-500 mt-0.5"><%= form_definition.slug %></p>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm">
    <% case form_definition.status %>
    <% when "draft" %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-900/50 text-yellow-300 border border-yellow-700">Draft</span>
    <% when "published" %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-900/50 text-green-300 border border-green-700">Published</span>
    <% when "archived" %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-700 text-gray-400 border border-gray-600">Archived</span>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <%= form_definition.field_definitions.size %> fields
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <%= form_definition.form_submissions.count %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400">
    <%= form_definition.created_at.strftime("%b %d, %Y") %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to "Edit", edit_form_definition_path(form_definition.uuid), class: "text-gray-400 hover:text-gray-200 mr-3" %>
    <%= button_to "Delete", form_definition_path(form_definition.uuid), method: :delete, class: "text-red-400 hover:text-red-300", form: { data: { turbo_confirm: "Are you sure you want to delete this form?" } } %>
  </td>
</tr>
