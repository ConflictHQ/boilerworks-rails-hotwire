<% content_for(:page_title, "Forms") %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-semibold text-text">Form Definitions</h2>
  <%= link_to new_form_definition_path, class: "inline-flex items-center px-4 py-2 bg-primary hover:bg-primary-hover text-primary-fg rounded-lg text-sm font-medium transition-colors" do %>
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    New Form
  <% end %>
</div>

<div class="bg-bg-card border border-border rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-border">
    <thead class="bg-bg-card">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Name</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Status</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Fields</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Submissions</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Created</th>
        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-text-muted uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody id="form_definitions" class="divide-y divide-border">
      <% @form_definitions.each do |form_definition| %>
        <%= render form_definition %>
      <% end %>
    </tbody>
  </table>

  <% if @form_definitions.empty? %>
    <div class="px-6 py-12 text-center">
      <p class="text-text-muted">No form definitions found.</p>
      <%= link_to "Create your first form", new_form_definition_path, class: "text-primary hover:underline text-sm mt-2 inline-block" %>
    </div>
  <% end %>
</div>

<% if @pagy.pages > 1 %>
  <div class="mt-6 flex items-center justify-between">
    <p class="text-sm text-text-muted">
      Showing <%= @pagy.from %>-<%= @pagy.to %> of <%= @pagy.count %> forms
    </p>
    <nav class="flex items-center space-x-1">
      <% if @pagy.prev %>
        <%= link_to "Previous", form_definitions_path(page: @pagy.prev), class: "px-3 py-2 rounded-lg bg-bg-card border border-border text-sm text-text-muted hover:bg-accent hover:text-text" %>
      <% end %>
      <% if @pagy.next %>
        <%= link_to "Next", form_definitions_path(page: @pagy.next), class: "px-3 py-2 rounded-lg bg-bg-card border border-border text-sm text-text-muted hover:bg-accent hover:text-text" %>
      <% end %>
    </nav>
  </div>
<% end %>
