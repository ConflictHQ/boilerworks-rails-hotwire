<%= form_with(model: workflow_definition, class: "space-y-6", data: { controller: "workflow-builder" }) do |form| %>
  <% if workflow_definition.errors.any? %>
    <div class="px-4 py-3 bg-destructive/10 border border-destructive/30 text-destructive rounded-lg">
      <h3 class="text-sm font-medium mb-2"><%= pluralize(workflow_definition.errors.count, "error") %> prohibited this workflow from being saved:</h3>
      <ul class="list-disc list-inside text-sm space-y-1">
        <% workflow_definition.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-text-muted mb-1" %>
    <%= form.text_field :name, required: true, class: "block w-full rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent", placeholder: "Workflow name" %>
  </div>

  <div>
    <%= form.label :slug, class: "block text-sm font-medium text-text-muted mb-1" %>
    <%= form.text_field :slug, required: true, class: "block w-full rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent", placeholder: "workflow-slug" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-text-muted mb-1" %>
    <%= form.text_area :description, rows: 3, class: "block w-full rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent", placeholder: "Describe this workflow" %>
  </div>

  <div>
    <%= form.label :target_type, class: "block text-sm font-medium text-text-muted mb-1" %>
    <%= form.text_field :target_type, class: "block w-full rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent", placeholder: "e.g. Item, Category (optional)" %>
  </div>

  <%= form.hidden_field :states, value: (workflow_definition.states || []).to_json, data: { workflow_builder_target: "statesInput" } %>
  <%= form.hidden_field :transitions, value: (workflow_definition.transitions || []).to_json, data: { workflow_builder_target: "transitionsInput" } %>

  <div class="border border-border rounded-lg p-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-semibold text-text uppercase tracking-wider">States</h3>
      <button type="button" data-action="workflow-builder#addState" class="inline-flex items-center px-3 py-1.5 bg-bg-input hover:bg-accent text-text rounded-lg text-xs font-medium transition-colors border border-border">
        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add State
      </button>
    </div>
    <div data-workflow-builder-target="stateList" class="space-y-2">
      <% (workflow_definition.states || []).each_with_index do |state, index| %>
        <div class="flex items-center gap-3 state-row" data-index="<%= index %>">
          <input type="text" value="<%= state['name'] %>" placeholder="State name" data-field="name" class="flex-1 rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" data-action="input->workflow-builder#updateJson">
          <label class="flex items-center gap-1.5 text-xs text-text-muted">
            <input type="checkbox" data-field="initial" <%= "checked" if state["initial"] %> class="rounded bg-bg-input border-input-border text-primary focus:ring-primary" data-action="change->workflow-builder#updateJson">
            Initial
          </label>
          <button type="button" data-action="workflow-builder#removeState" class="text-destructive hover:underline text-sm">Remove</button>
        </div>
      <% end %>
    </div>
  </div>

  <div class="border border-border rounded-lg p-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-semibold text-text uppercase tracking-wider">Transitions</h3>
      <button type="button" data-action="workflow-builder#addTransition" class="inline-flex items-center px-3 py-1.5 bg-bg-input hover:bg-accent text-text rounded-lg text-xs font-medium transition-colors border border-border">
        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Transition
      </button>
    </div>
    <div data-workflow-builder-target="transitionList" class="space-y-2">
      <% (workflow_definition.transitions || []).each_with_index do |transition, index| %>
        <div class="flex items-center gap-3 transition-row" data-index="<%= index %>">
          <input type="text" value="<%= transition['from'] %>" placeholder="From state" data-field="from" class="flex-1 rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" data-action="input->workflow-builder#updateJson">
          <svg class="w-4 h-4 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
          <input type="text" value="<%= transition['to'] %>" placeholder="To state" data-field="to" class="flex-1 rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" data-action="input->workflow-builder#updateJson">
          <button type="button" data-action="workflow-builder#removeTransition" class="text-destructive hover:underline text-sm">Remove</button>
        </div>
      <% end %>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= form.submit class: "rounded-lg px-4 py-2.5 bg-primary hover:bg-primary-hover text-primary-fg font-medium cursor-pointer transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-bg" %>
    <%= link_to "Cancel", workflow_definitions_path, class: "rounded-lg px-4 py-2.5 bg-bg-input hover:bg-accent text-text font-medium transition-colors border border-border" %>
  </div>
<% end %>
