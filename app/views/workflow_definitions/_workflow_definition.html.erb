<tr id="<%= dom_id(workflow_definition) %>" class="hover:bg-gray-750">
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-100">
    <%= link_to workflow_definition.name, workflow_definition_path(workflow_definition.uuid), class: "text-red-400 hover:text-red-300" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <code class="text-xs bg-gray-700 px-2 py-1 rounded"><%= workflow_definition.slug %></code>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <%= workflow_definition.state_names.size %> states
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <%= workflow_definition.target_type.present? ? workflow_definition.target_type : "&mdash;".html_safe %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400">
    <%= workflow_definition.created_at.strftime("%b %d, %Y") %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to "Edit", edit_workflow_definition_path(workflow_definition.uuid), class: "text-gray-400 hover:text-gray-200 mr-3" %>
    <%= button_to "Delete", workflow_definition_path(workflow_definition.uuid), method: :delete, class: "text-red-400 hover:text-red-300", form: { data: { turbo_confirm: "Are you sure you want to delete this workflow definition?" } } %>
  </td>
</tr>
