<tr id="<%= dom_id(workflow_definition) %>" class="hover:bg-accent">
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= link_to workflow_definition.name, workflow_definition_path(workflow_definition.uuid), class: "text-primary hover:underline" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <code class="text-xs bg-accent px-2 py-1 rounded"><%= workflow_definition.slug %></code>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= workflow_definition.state_names.size %> states
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= workflow_definition.target_type.present? ? workflow_definition.target_type : "&mdash;".html_safe %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text-muted">
    <%= workflow_definition.created_at.strftime("%b %d, %Y") %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to "Edit", edit_workflow_definition_path(workflow_definition.uuid), class: "text-primary hover:underline mr-3" %>
    <%= button_to "Delete", workflow_definition_path(workflow_definition.uuid), method: :delete, class: "text-destructive hover:underline", form: { data: { turbo_confirm: "Are you sure you want to delete this workflow definition?" } } %>
  </td>
</tr>
