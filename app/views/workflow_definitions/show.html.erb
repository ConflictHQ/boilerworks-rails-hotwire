<% content_for(:page_title, @workflow_definition.name) %>

<div class="mb-6">
  <%= link_to workflow_definitions_path, class: "inline-flex items-center text-sm text-text-muted hover:text-text" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Workflows
  <% end %>
</div>

<div class="bg-bg-card border border-border rounded-lg p-6 mb-6">
  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-text"><%= @workflow_definition.name %></h2>
      <p class="text-sm text-text-muted mt-1">slug: <%= @workflow_definition.slug %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_workflow_definition_path(@workflow_definition.uuid), class: "inline-flex items-center px-4 py-2 bg-bg-input hover:bg-accent text-text rounded-lg text-sm font-medium transition-colors border border-border" %>
      <%= button_to "Delete", workflow_definition_path(@workflow_definition.uuid), method: :delete, class: "inline-flex items-center px-4 py-2 bg-destructive hover:bg-destructive/80 text-primary-fg rounded-lg text-sm font-medium transition-colors cursor-pointer", form: { data: { turbo_confirm: "Are you sure you want to delete this workflow definition?" } } %>
    </div>
  </div>

  <dl class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div class="md:col-span-2">
      <dt class="text-sm font-medium text-text-muted">Description</dt>
      <dd class="mt-1 text-text"><%= @workflow_definition.description || "No description" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-text-muted">Target Type</dt>
      <dd class="mt-1 text-text"><%= @workflow_definition.target_type.present? ? @workflow_definition.target_type : "None" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-text-muted">Instances</dt>
      <dd class="mt-1 text-text"><%= @workflow_definition.workflow_instances.count %></dd>
    </div>
  </dl>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-bg-card border border-border rounded-lg p-6">
    <h3 class="text-lg font-semibold text-text mb-4">States</h3>
    <% if @workflow_definition.states.any? %>
      <ul class="space-y-2">
        <% @workflow_definition.states.each do |state| %>
          <li class="flex items-center gap-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= state['initial'] ? 'bg-success/10 text-success' : 'bg-accent text-text-muted' %>">
              <%= state["name"] %>
            </span>
            <% if state["initial"] %>
              <span class="text-xs text-success">(initial)</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-text-muted text-sm">No states defined.</p>
    <% end %>
  </div>

  <div class="bg-bg-card border border-border rounded-lg p-6">
    <h3 class="text-lg font-semibold text-text mb-4">Transitions</h3>
    <% if @workflow_definition.transitions.any? %>
      <ul class="space-y-2">
        <% @workflow_definition.transitions.each do |transition| %>
          <li class="flex items-center gap-2 text-sm">
            <span class="text-text"><%= transition["from"] %></span>
            <svg class="w-4 h-4 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
            <span class="text-text"><%= transition["to"] %></span>
            <% if transition["conditions"]&.any? %>
              <span class="text-xs text-yellow-400">(conditional)</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-text-muted text-sm">No transitions defined.</p>
    <% end %>
  </div>
</div>
