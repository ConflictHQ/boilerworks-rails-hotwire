<% content_for(:page_title, "Products") %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-semibold text-gray-100">Products</h2>
  <%= link_to new_product_path, class: "inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-medium transition-colors" do %>
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    New Product
  <% end %>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-700">
    <thead class="bg-gray-800">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Name</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Category</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Price</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Created</th>
        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody id="products" class="divide-y divide-gray-700">
      <% @products.each do |product| %>
        <%= render product %>
      <% end %>
    </tbody>
  </table>

  <% if @products.empty? %>
    <div class="px-6 py-12 text-center">
      <p class="text-gray-400">No products found.</p>
      <%= link_to "Create your first product", new_product_path, class: "text-red-400 hover:text-red-300 text-sm mt-2 inline-block" %>
    </div>
  <% end %>
</div>

<% if @pagy.pages > 1 %>
  <div class="mt-6 flex items-center justify-between">
    <p class="text-sm text-gray-400">
      Showing <%= @pagy.from %>-<%= @pagy.to %> of <%= @pagy.count %> products
    </p>
    <nav class="flex items-center space-x-1">
      <% if @pagy.prev %>
        <%= link_to "Previous", products_path(page: @pagy.prev), class: "px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-300 hover:bg-gray-700" %>
      <% end %>
      <% if @pagy.next %>
        <%= link_to "Next", products_path(page: @pagy.next), class: "px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-gray-300 hover:bg-gray-700" %>
      <% end %>
    </nav>
  </div>
<% end %>
