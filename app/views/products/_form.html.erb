<%= form_with(model: product, class: "space-y-6") do |form| %>
  <% if product.errors.any? %>
    <div class="px-4 py-3 bg-red-900/50 border border-red-700 text-red-300 rounded-lg">
      <h3 class="text-sm font-medium mb-2"><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h3>
      <ul class="list-disc list-inside text-sm space-y-1">
        <% product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-300 mb-1" %>
    <%= form.text_field :name, required: true, class: "block w-full rounded-lg bg-gray-700 border border-gray-600 text-gray-100 placeholder-gray-400 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent", placeholder: "Product name" %>
  </div>

  <div>
    <%= form.label :slug, class: "block text-sm font-medium text-gray-300 mb-1" %>
    <%= form.text_field :slug, class: "block w-full rounded-lg bg-gray-700 border border-gray-600 text-gray-100 placeholder-gray-400 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent", placeholder: "product-slug" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-300 mb-1" %>
    <%= form.text_area :description, rows: 4, class: "block w-full rounded-lg bg-gray-700 border border-gray-600 text-gray-100 placeholder-gray-400 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent", placeholder: "Product description" %>
  </div>

  <div>
    <%= form.label :price, class: "block text-sm font-medium text-gray-300 mb-1" %>
    <%= form.number_field :price, step: 0.01, min: 0, class: "block w-full rounded-lg bg-gray-700 border border-gray-600 text-gray-100 placeholder-gray-400 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent", placeholder: "0.00" %>
  </div>

  <div>
    <%= form.label :category_id, "Category", class: "block text-sm font-medium text-gray-300 mb-1" %>
    <%= form.collection_select :category_id, @categories, :id, :name, { include_blank: "No category" }, class: "block w-full rounded-lg bg-gray-700 border border-gray-600 text-gray-100 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent" %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= form.submit class: "rounded-lg px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white font-medium cursor-pointer transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 focus:ring-offset-gray-800" %>
    <%= link_to "Cancel", products_path, class: "rounded-lg px-4 py-2.5 bg-gray-700 hover:bg-gray-600 text-gray-200 font-medium transition-colors border border-gray-600" %>
  </div>
<% end %>
