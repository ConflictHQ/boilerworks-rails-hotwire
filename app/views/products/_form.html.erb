<%= form_with(model: product, class: "space-y-6") do |form| %>
  <% if product.errors.any? %>
    <div class="px-4 py-3 bg-destructive/10 border border-destructive/30 text-destructive rounded-lg">
      <h3 class="text-sm font-medium mb-2"><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h3>
      <ul class="list-disc list-inside text-sm space-y-1">
        <% product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-text-muted mb-1" %>
    <%= form.text_field :name, required: true, class: "block w-full rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent", placeholder: "Product name" %>
  </div>

  <div>
    <%= form.label :slug, class: "block text-sm font-medium text-text-muted mb-1" %>
    <%= form.text_field :slug, class: "block w-full rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent", placeholder: "product-slug" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-text-muted mb-1" %>
    <%= form.text_area :description, rows: 4, class: "block w-full rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent", placeholder: "Product description" %>
  </div>

  <div>
    <%= form.label :price, class: "block text-sm font-medium text-text-muted mb-1" %>
    <%= form.number_field :price, step: 0.01, min: 0, class: "block w-full rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent", placeholder: "0.00" %>
  </div>

  <div>
    <%= form.label :category_id, "Category", class: "block text-sm font-medium text-text-muted mb-1" %>
    <%= form.collection_select :category_id, @categories, :id, :name, { include_blank: "No category" }, class: "block w-full rounded-md bg-bg-input border border-input-border text-text px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= form.submit class: "rounded-lg px-4 py-2.5 bg-primary hover:bg-primary-hover text-primary-fg font-medium cursor-pointer transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-bg" %>
    <%= link_to "Cancel", products_path, class: "rounded-lg px-4 py-2.5 bg-bg-input hover:bg-accent text-text font-medium transition-colors border border-border" %>
  </div>
<% end %>
