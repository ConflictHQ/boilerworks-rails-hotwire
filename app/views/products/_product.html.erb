<tr id="<%= dom_id(product) %>" class="hover:bg-gray-750">
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-100">
    <%= link_to product.name, product_path(product.uuid), class: "text-red-400 hover:text-red-300" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <%= product.category&.name || "Uncategorized" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <% if product.price %>
      $<%= number_with_precision(product.price, precision: 2) %>
    <% else %>
      <span class="text-gray-500">&mdash;</span>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400">
    <%= product.created_at.strftime("%b %d, %Y") %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to "Edit", edit_product_path(product.uuid), class: "text-gray-400 hover:text-gray-200 mr-3" %>
    <%= button_to "Delete", product_path(product.uuid), method: :delete, class: "text-red-400 hover:text-red-300", form: { data: { turbo_confirm: "Are you sure you want to delete this product?" } } %>
  </td>
</tr>
