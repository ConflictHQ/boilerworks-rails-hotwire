<tr id="<%= dom_id(product) %>" class="hover:bg-accent">
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= link_to product.name, product_path(product.uuid), class: "text-primary hover:underline" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= product.category&.name || "Uncategorized" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <% if product.price %>
      $<%= number_with_precision(product.price, precision: 2) %>
    <% else %>
      <span class="text-text-muted">&mdash;</span>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text-muted">
    <%= product.created_at.strftime("%b %d, %Y") %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to "Edit", edit_product_path(product.uuid), class: "text-primary hover:underline mr-3" %>
    <%= button_to "Delete", product_path(product.uuid), method: :delete, class: "text-destructive hover:underline", form: { data: { turbo_confirm: "Are you sure you want to delete this product?" } } %>
  </td>
</tr>
