<% content_for(:page_title, @product.name) %>

<div class="mb-6">
  <%= link_to products_path, class: "inline-flex items-center text-sm text-text-muted hover:text-text" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Products
  <% end %>
</div>

<div class="bg-bg-card border border-border rounded-lg p-6">
  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-text"><%= @product.name %></h2>
      <% if @product.slug %>
        <p class="text-sm text-text-muted mt-1">slug: <%= @product.slug %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_product_path(@product.uuid), class: "inline-flex items-center px-4 py-2 bg-bg-input hover:bg-accent text-text rounded-lg text-sm font-medium transition-colors border border-border" %>
      <%= button_to "Delete", product_path(@product.uuid), method: :delete, class: "inline-flex items-center px-4 py-2 bg-destructive hover:bg-destructive/80 text-primary-fg rounded-lg text-sm font-medium transition-colors cursor-pointer", form: { data: { turbo_confirm: "Are you sure you want to delete this product?" } } %>
    </div>
  </div>

  <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <dt class="text-sm font-medium text-text-muted">Category</dt>
      <dd class="mt-1 text-text"><%= @product.category&.name || "Uncategorized" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-text-muted">Price</dt>
      <dd class="mt-1 text-text">
        <% if @product.price %>
          $<%= number_with_precision(@product.price, precision: 2) %>
        <% else %>
          <span class="text-text-muted">Not set</span>
        <% end %>
      </dd>
    </div>

    <div class="md:col-span-2">
      <dt class="text-sm font-medium text-text-muted">Description</dt>
      <dd class="mt-1 text-text"><%= @product.description || "No description" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-text-muted">Created</dt>
      <dd class="mt-1 text-text-muted text-sm"><%= @product.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-text-muted">Updated</dt>
      <dd class="mt-1 text-text-muted text-sm"><%= @product.updated_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
    </div>
  </dl>
</div>
