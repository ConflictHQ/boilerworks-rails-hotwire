<% content_for(:page_title, @product.name) %>

<div class="mb-6">
  <%= link_to products_path, class: "inline-flex items-center text-sm text-gray-400 hover:text-gray-200" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Products
  <% end %>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-gray-100"><%= @product.name %></h2>
      <% if @product.slug %>
        <p class="text-sm text-gray-400 mt-1">slug: <%= @product.slug %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_product_path(@product.uuid), class: "inline-flex items-center px-4 py-2 bg-gray-700 hover:bg-gray-600 text-gray-200 rounded-lg text-sm font-medium transition-colors border border-gray-600" %>
      <%= button_to "Delete", product_path(@product.uuid), method: :delete, class: "inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer", form: { data: { turbo_confirm: "Are you sure you want to delete this product?" } } %>
    </div>
  </div>

  <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <dt class="text-sm font-medium text-gray-400">Category</dt>
      <dd class="mt-1 text-gray-100"><%= @product.category&.name || "Uncategorized" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-400">Price</dt>
      <dd class="mt-1 text-gray-100">
        <% if @product.price %>
          $<%= number_with_precision(@product.price, precision: 2) %>
        <% else %>
          <span class="text-gray-500">Not set</span>
        <% end %>
      </dd>
    </div>

    <div class="md:col-span-2">
      <dt class="text-sm font-medium text-gray-400">Description</dt>
      <dd class="mt-1 text-gray-100"><%= @product.description || "No description" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-400">Created</dt>
      <dd class="mt-1 text-gray-300 text-sm"><%= @product.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-400">Updated</dt>
      <dd class="mt-1 text-gray-300 text-sm"><%= @product.updated_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
    </div>
  </dl>
</div>
