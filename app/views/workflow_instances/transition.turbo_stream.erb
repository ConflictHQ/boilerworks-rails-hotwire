<%= turbo_stream.replace "workflow_instance_detail" do %>
  <div class="bg-bg-card border border-border rounded-lg p-6 mb-6">
    <div class="flex items-start justify-between mb-6">
      <div>
        <h2 class="text-2xl font-bold text-text"><%= @workflow_instance.workflow_definition.name %></h2>
        <p class="text-sm text-text-muted mt-1 font-mono"><%= @workflow_instance.uuid %></p>
      </div>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-900/50 text-blue-300 border border-blue-700">
        <%= @workflow_instance.current_state %>
      </span>
    </div>

    <dl class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div>
        <dt class="text-sm font-medium text-text-muted">Workflow Definition</dt>
        <dd class="mt-1">
          <%= link_to @workflow_instance.workflow_definition.name, workflow_definition_path(@workflow_instance.workflow_definition.uuid), class: "text-primary hover:underline" %>
        </dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-text-muted">Created</dt>
        <dd class="mt-1 text-text-muted text-sm"><%= @workflow_instance.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
      </div>

      <% if @workflow_instance.workflowable.present? %>
        <div>
          <dt class="text-sm font-medium text-text-muted">Attached To</dt>
          <dd class="mt-1 text-text"><%= @workflow_instance.workflowable_type %> #<%= @workflow_instance.workflowable_id %></dd>
        </div>
      <% end %>

      <% if @workflow_instance.metadata.present? %>
        <div class="md:col-span-2">
          <dt class="text-sm font-medium text-text-muted">Metadata</dt>
          <dd class="mt-1">
            <pre class="text-xs bg-bg text-text-muted p-3 rounded-lg overflow-x-auto"><%= JSON.pretty_generate(@workflow_instance.metadata) %></pre>
          </dd>
        </div>
      <% end %>
    </dl>

    <% if @workflow_instance.available_transitions.any? %>
      <div class="border-t border-border pt-4">
        <h3 class="text-sm font-semibold text-text uppercase tracking-wider mb-3">Available Transitions</h3>
        <div class="flex flex-wrap gap-2">
          <% @workflow_instance.available_transitions.each do |transition| %>
            <%= button_to transition_workflow_instance_path(@workflow_instance.uuid),
                  params: { to_state: transition["to"] },
                  class: "inline-flex items-center px-3 py-1.5 bg-bg-input hover:bg-accent text-text rounded-lg text-sm font-medium transition-colors border border-border cursor-pointer" do %>
              <svg class="w-3.5 h-3.5 mr-1.5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
              <%= transition["to"] %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="border-t border-border pt-4">
        <p class="text-sm text-text-muted">No transitions available from the current state.</p>
      </div>
    <% end %>
  </div>
<% end %>
