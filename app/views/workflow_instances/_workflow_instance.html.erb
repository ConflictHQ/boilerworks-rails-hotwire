<tr id="<%= dom_id(workflow_instance) %>" class="hover:bg-gray-750">
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-100">
    <%= link_to workflow_instance.uuid&.first(8), workflow_instance_path(workflow_instance.uuid), class: "text-red-400 hover:text-red-300 font-mono" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <%= link_to workflow_instance.workflow_definition.name, workflow_definition_path(workflow_instance.workflow_definition.uuid), class: "text-gray-300 hover:text-gray-100" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm">
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-900 text-blue-300">
      <%= workflow_instance.current_state %>
    </span>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400">
    <%= workflow_instance.created_at.strftime("%b %d, %Y") %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to "View", workflow_instance_path(workflow_instance.uuid), class: "text-gray-400 hover:text-gray-200" %>
  </td>
</tr>
