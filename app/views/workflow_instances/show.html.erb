<% content_for(:page_title, "Workflow Instance") %>

<div class="mb-6">
  <%= link_to workflow_instances_path, class: "inline-flex items-center text-sm text-gray-400 hover:text-gray-200" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Instances
  <% end %>
</div>

<%= turbo_frame_tag "workflow_instance_detail" do %>
  <div class="bg-gray-800 border border-gray-700 rounded-lg p-6 mb-6">
    <div class="flex items-start justify-between mb-6">
      <div>
        <h2 class="text-2xl font-bold text-gray-100"><%= @workflow_instance.workflow_definition.name %></h2>
        <p class="text-sm text-gray-400 mt-1 font-mono"><%= @workflow_instance.uuid %></p>
      </div>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-900 text-blue-300">
        <%= @workflow_instance.current_state %>
      </span>
    </div>

    <dl class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div>
        <dt class="text-sm font-medium text-gray-400">Workflow Definition</dt>
        <dd class="mt-1">
          <%= link_to @workflow_instance.workflow_definition.name, workflow_definition_path(@workflow_instance.workflow_definition.uuid), class: "text-red-400 hover:text-red-300" %>
        </dd>
      </div>

      <div>
        <dt class="text-sm font-medium text-gray-400">Created</dt>
        <dd class="mt-1 text-gray-300 text-sm"><%= @workflow_instance.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
      </div>

      <% if @workflow_instance.workflowable.present? %>
        <div>
          <dt class="text-sm font-medium text-gray-400">Attached To</dt>
          <dd class="mt-1 text-gray-100"><%= @workflow_instance.workflowable_type %> #<%= @workflow_instance.workflowable_id %></dd>
        </div>
      <% end %>

      <% if @workflow_instance.metadata.present? %>
        <div class="md:col-span-2">
          <dt class="text-sm font-medium text-gray-400">Metadata</dt>
          <dd class="mt-1">
            <pre class="text-xs bg-gray-900 text-gray-300 p-3 rounded-lg overflow-x-auto"><%= JSON.pretty_generate(@workflow_instance.metadata) %></pre>
          </dd>
        </div>
      <% end %>
    </dl>

    <% if @workflow_instance.available_transitions.any? %>
      <div class="border-t border-gray-700 pt-4">
        <h3 class="text-sm font-semibold text-gray-200 uppercase tracking-wider mb-3">Available Transitions</h3>
        <div class="flex flex-wrap gap-2">
          <% @workflow_instance.available_transitions.each do |transition| %>
            <%= button_to transition_workflow_instance_path(@workflow_instance.uuid),
                  params: { to_state: transition["to"] },
                  class: "inline-flex items-center px-3 py-1.5 bg-gray-700 hover:bg-gray-600 text-gray-200 rounded-lg text-sm font-medium transition-colors border border-gray-600 cursor-pointer" do %>
              <svg class="w-3.5 h-3.5 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
              <%= transition["to"] %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="border-t border-gray-700 pt-4">
        <p class="text-sm text-gray-400">No transitions available from the current state.</p>
      </div>
    <% end %>
  </div>
<% end %>

<div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
  <h3 class="text-lg font-semibold text-gray-100 mb-4">Transition Log</h3>

  <% if @workflow_instance.transition_logs.any? %>
    <div class="relative">
      <div class="absolute left-4 top-0 bottom-0 w-px bg-gray-700"></div>
      <ul class="space-y-4">
        <% @workflow_instance.transition_logs.each do |log| %>
          <li class="relative pl-10">
            <div class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full bg-gray-600 border-2 border-gray-800"></div>
            <div class="bg-gray-750 border border-gray-700 rounded-lg p-3">
              <div class="flex items-center gap-2 text-sm">
                <span class="text-gray-300"><%= log.from_state %></span>
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
                <span class="font-medium text-gray-100"><%= log.to_state %></span>
              </div>
              <div class="flex items-center gap-3 mt-1 text-xs text-gray-400">
                <span><%= log.created_at.strftime("%b %d, %Y at %I:%M %p") %></span>
                <% if log.transitioned_by.present? %>
                  <span>by <%= log.transitioned_by.email_address %></span>
                <% end %>
              </div>
              <% if log.data.present? && log.data.any? %>
                <pre class="text-xs bg-gray-900 text-gray-300 p-2 rounded mt-2 overflow-x-auto"><%= JSON.pretty_generate(log.data) %></pre>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <p class="text-gray-400 text-sm">No transitions have been recorded yet.</p>
  <% end %>
</div>
