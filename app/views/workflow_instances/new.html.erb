<% content_for(:page_title, "New Workflow Instance") %>

<div class="mb-6">
  <%= link_to workflow_instances_path, class: "inline-flex items-center text-sm text-text-muted hover:text-text" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Instances
  <% end %>
</div>

<div class="bg-bg-card border border-border rounded-lg p-6">
  <h2 class="text-xl font-semibold text-text mb-6">New Workflow Instance</h2>

  <%= form_with(model: @workflow_instance, class: "space-y-6") do |form| %>
    <% if @workflow_instance.errors.any? %>
      <div class="px-4 py-3 bg-destructive/10 border border-destructive/30 text-destructive rounded-lg">
        <h3 class="text-sm font-medium mb-2"><%= pluralize(@workflow_instance.errors.count, "error") %> prohibited this instance from being saved:</h3>
        <ul class="list-disc list-inside text-sm space-y-1">
          <% @workflow_instance.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :workflow_definition_id, "Workflow Definition", class: "block text-sm font-medium text-text-muted mb-1" %>
      <%= form.collection_select :workflow_definition_id, @workflow_definitions, :id, :name, { prompt: "Select a workflow" }, class: "block w-full rounded-md bg-bg-input border border-input-border text-text px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= form.submit "Create Instance", class: "rounded-lg px-4 py-2.5 bg-primary hover:bg-primary-hover text-primary-fg font-medium cursor-pointer transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-bg" %>
      <%= link_to "Cancel", workflow_instances_path, class: "rounded-lg px-4 py-2.5 bg-bg-input hover:bg-accent text-text font-medium transition-colors border border-border" %>
    </div>
  <% end %>
</div>
