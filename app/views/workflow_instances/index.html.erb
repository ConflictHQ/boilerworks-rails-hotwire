<% content_for(:page_title, "Workflow Instances") %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-semibold text-text">Workflow Instances</h2>
  <%= link_to new_workflow_instance_path, class: "inline-flex items-center px-4 py-2 bg-primary hover:bg-primary-hover text-primary-fg rounded-lg text-sm font-medium transition-colors" do %>
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    New Instance
  <% end %>
</div>

<div class="bg-bg-card border border-border rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-border">
    <thead class="bg-bg-card">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">ID</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Workflow</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Current State</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Created</th>
        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-text-muted uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody id="workflow_instances" class="divide-y divide-border">
      <% @workflow_instances.each do |workflow_instance| %>
        <%= render workflow_instance %>
      <% end %>
    </tbody>
  </table>

  <% if @workflow_instances.empty? %>
    <div class="px-6 py-12 text-center">
      <p class="text-text-muted">No workflow instances found.</p>
      <%= link_to "Create your first instance", new_workflow_instance_path, class: "text-primary hover:underline text-sm mt-2 inline-block" %>
    </div>
  <% end %>
</div>
