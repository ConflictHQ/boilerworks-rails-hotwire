<% content_for(:page_title, "Dashboard") %>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-400">Products</p>
        <p class="text-3xl font-bold text-gray-100 mt-1"><%= @products_count %></p>
      </div>
      <div class="w-12 h-12 bg-red-900/30 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
      </div>
    </div>
    <div class="mt-4">
      <%= link_to "View all", products_path, class: "text-sm text-red-400 hover:text-red-300" %>
    </div>
  </div>

  <div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-400">Categories</p>
        <p class="text-3xl font-bold text-gray-100 mt-1"><%= @categories_count %></p>
      </div>
      <div class="w-12 h-12 bg-blue-900/30 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
        </svg>
      </div>
    </div>
    <div class="mt-4">
      <%= link_to "View all", categories_path, class: "text-sm text-blue-400 hover:text-blue-300" %>
    </div>
  </div>

  <div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-400">Users</p>
        <p class="text-3xl font-bold text-gray-100 mt-1"><%= @users_count %></p>
      </div>
      <div class="w-12 h-12 bg-green-900/30 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
      </div>
    </div>
  </div>
</div>

<div class="bg-gray-800 border border-gray-700 rounded-lg p-6">
  <h2 class="text-lg font-semibold text-gray-100 mb-4">Quick Actions</h2>
  <div class="flex flex-wrap gap-3">
    <%= link_to new_product_path, class: "inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-medium transition-colors" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Product
    <% end %>

    <%= link_to new_category_path, class: "inline-flex items-center px-4 py-2 bg-gray-700 hover:bg-gray-600 text-gray-200 rounded-lg text-sm font-medium transition-colors border border-gray-600" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Category
    <% end %>
  </div>
</div>
