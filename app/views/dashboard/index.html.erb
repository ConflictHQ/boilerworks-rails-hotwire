<% content_for(:page_title, "Dashboard") %>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-bg-card border border-border rounded-lg p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-text-muted">Items</p>
        <p class="text-3xl font-bold text-text mt-1"><%= @items_count %></p>
      </div>
      <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
      </div>
    </div>
    <div class="mt-4">
      <%= link_to "View all", items_path, class: "text-sm text-primary hover:underline" %>
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-lg p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-text-muted">Categories</p>
        <p class="text-3xl font-bold text-text mt-1"><%= @categories_count %></p>
      </div>
      <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
        </svg>
      </div>
    </div>
    <div class="mt-4">
      <%= link_to "View all", categories_path, class: "text-sm text-primary hover:underline" %>
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-lg p-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-text-muted">Users</p>
        <p class="text-3xl font-bold text-text mt-1"><%= @users_count %></p>
      </div>
      <div class="w-12 h-12 bg-success/10 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
      </div>
    </div>
  </div>
</div>

<div class="bg-bg-card border border-border rounded-lg p-6">
  <h2 class="text-lg font-semibold text-text mb-4">Quick Actions</h2>
  <div class="flex flex-wrap gap-3">
    <%= link_to new_item_path, class: "inline-flex items-center px-4 py-2 bg-primary hover:bg-primary-hover text-primary-fg rounded-lg text-sm font-medium transition-colors" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Item
    <% end %>

    <%= link_to new_category_path, class: "inline-flex items-center px-4 py-2 bg-bg-input hover:bg-accent text-text rounded-lg text-sm font-medium transition-colors border border-border" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Category
    <% end %>
  </div>
</div>
