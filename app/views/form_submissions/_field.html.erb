<%
  field_name = field["name"]
  field_type = field["type"]
  field_label = field["label"] || field_name.titleize
  placeholder = field["placeholder"] || ""
  validations = field["validations"] || {}
  required = validations["required"]
  options = field["options"] || []
  input_name = "submission[#{field_name}]"
  input_class = "block w-full rounded-md bg-bg-input border border-input-border text-text placeholder-text-muted px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
%>

<% unless field_type == "hidden" %>
  <div>
    <label for="submission_<%= field_name %>" class="block text-sm font-medium text-text-muted mb-1">
      <%= field_label %>
      <% if required %>
        <span class="text-destructive">*</span>
      <% end %>
    </label>
<% end %>

<% case field_type %>
<% when "text", "phone" %>
    <input type="text" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value %>" placeholder="<%= placeholder %>" class="<%= input_class %>" <%= "required" if required %> <%= "minlength=#{validations['min_length']}" if validations["min_length"] %> <%= "maxlength=#{validations['max_length']}" if validations["max_length"] %> <%= "pattern=#{validations['pattern']}" if validations["pattern"] %>>

<% when "email" %>
    <input type="email" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value %>" placeholder="<%= placeholder %>" class="<%= input_class %>" <%= "required" if required %>>

<% when "url" %>
    <input type="url" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value %>" placeholder="<%= placeholder.presence || 'https://' %>" class="<%= input_class %>" <%= "required" if required %>>

<% when "textarea", "rich_text" %>
    <textarea name="<%= input_name %>" id="submission_<%= field_name %>" rows="4" placeholder="<%= placeholder %>" class="<%= input_class %>" <%= "required" if required %> <%= "minlength=#{validations['min_length']}" if validations["min_length"] %> <%= "maxlength=#{validations['max_length']}" if validations["max_length"] %>><%= value %></textarea>

<% when "number" %>
    <input type="number" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value %>" placeholder="<%= placeholder %>" class="<%= input_class %>" <%= "required" if required %> <%= "min=#{validations['min']}" if validations["min"] %> <%= "max=#{validations['max']}" if validations["max"] %> <%= "step=#{validations['step']}" if validations["step"] %>>

<% when "rating" %>
    <input type="number" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value %>" class="<%= input_class %>" <%= "required" if required %> min="<%= validations['min'] || 1 %>" max="<%= validations['max'] || 5 %>" step="1">
    <p class="text-xs text-text-muted mt-1">Rate from <%= validations['min'] || 1 %> to <%= validations['max'] || 5 %></p>

<% when "slider" %>
    <input type="range" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value || validations['min'] || 0 %>" class="w-full accent-primary" <%= "required" if required %> min="<%= validations['min'] || 0 %>" max="<%= validations['max'] || 100 %>" step="<%= validations['step'] || 1 %>">
    <div class="flex justify-between text-xs text-text-muted mt-1">
      <span><%= validations['min'] || 0 %></span>
      <span><%= validations['max'] || 100 %></span>
    </div>

<% when "date" %>
    <input type="date" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value %>" class="<%= input_class %>" <%= "required" if required %> <%= "min=#{validations['min']}" if validations["min"] %> <%= "max=#{validations['max']}" if validations["max"] %>>

<% when "time" %>
    <input type="time" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value %>" class="<%= input_class %>" <%= "required" if required %>>

<% when "datetime" %>
    <input type="datetime-local" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value %>" class="<%= input_class %>" <%= "required" if required %>>

<% when "select" %>
    <select name="<%= input_name %>" id="submission_<%= field_name %>" class="<%= input_class %>" <%= "required" if required %>>
      <option value="">Select an option...</option>
      <% options.each do |option| %>
        <option value="<%= option["value"] %>" <%= "selected" if value == option["value"] %>><%= option["label"] || option["value"] %></option>
      <% end %>
    </select>

<% when "multi_select" %>
    <select name="<%= input_name %>[]" id="submission_<%= field_name %>" class="<%= input_class %>" multiple size="<%= [options.size, 6].min %>" <%= "required" if required %>>
      <% options.each do |option| %>
        <option value="<%= option["value"] %>" <%= "selected" if Array(value).include?(option["value"]) %>><%= option["label"] || option["value"] %></option>
      <% end %>
    </select>
    <p class="text-xs text-text-muted mt-1">Hold Ctrl/Cmd to select multiple options</p>

<% when "radio" %>
    <div class="space-y-2 mt-1">
      <% options.each_with_index do |option, i| %>
        <label class="flex items-center gap-2 text-sm text-text cursor-pointer">
          <input type="radio" name="<%= input_name %>" value="<%= option["value"] %>" class="text-primary bg-bg-input border-input-border focus:ring-primary" <%= "checked" if value == option["value"] %> <%= "required" if required && i == 0 %>>
          <%= option["label"] || option["value"] %>
        </label>
      <% end %>
    </div>

<% when "checkbox" %>
    <div class="mt-1">
      <label class="flex items-center gap-2 text-sm text-text cursor-pointer">
        <input type="hidden" name="<%= input_name %>" value="0">
        <input type="checkbox" name="<%= input_name %>" value="1" class="rounded bg-bg-input border-input-border text-primary focus:ring-primary" <%= "checked" if value.to_s == "1" || value == true %> <%= "required" if required %>>
        <%= field_label %>
      </label>
    </div>

<% when "toggle" %>
    <div class="mt-1">
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="hidden" name="<%= input_name %>" value="0">
        <input type="checkbox" name="<%= input_name %>" value="1" class="sr-only peer" <%= "checked" if value.to_s == "1" || value == true %>>
        <div class="relative w-11 h-6 bg-accent peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
        <span class="text-sm text-text"><%= field_label %></span>
      </label>
    </div>

<% when "color" %>
    <input type="color" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value || '#ef4444' %>" class="h-10 w-20 rounded bg-bg-input border border-input-border cursor-pointer" <%= "required" if required %>>

<% when "file", "image" %>
    <input type="file" name="<%= input_name %>" id="submission_<%= field_name %>" class="block w-full text-sm text-text-muted file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-accent file:text-text hover:file:bg-accent/80 cursor-pointer" <%= "required" if required %> <%= "accept=image/*" if field_type == "image" %> <%= "accept=#{validations['accept']}" if validations["accept"] %>>
    <% if validations["max_size"] %>
      <p class="text-xs text-text-muted mt-1">Max size: <%= validations["max_size"] %></p>
    <% end %>

<% when "signature" %>
    <div class="bg-bg border border-input-border rounded-lg p-4 text-center">
      <p class="text-sm text-text-muted">Signature capture requires JavaScript. Use the drawing area below.</p>
      <textarea name="<%= input_name %>" id="submission_<%= field_name %>" rows="3" placeholder="Type your signature..." class="<%= input_class %> mt-2" <%= "required" if required %>><%= value %></textarea>
    </div>

<% when "hidden" %>
    <input type="hidden" name="<%= input_name %>" id="submission_<%= field_name %>" value="<%= value || field["default_value"] %>">

<% end %>

<% unless field_type == "hidden" %>
  </div>
<% end %>
