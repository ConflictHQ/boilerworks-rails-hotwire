<% content_for(:page_title, "Form Submissions") %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-xl font-semibold text-text">Form Submissions</h2>
</div>

<div class="bg-bg-card border border-border rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-border">
    <thead class="bg-bg-card">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Form</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Status</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Submitted By</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-text-muted uppercase tracking-wider">Submitted</th>
        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-text-muted uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-border">
      <% @form_submissions.each do |submission| %>
        <tr class="hover:bg-accent">
          <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
            <%= link_to submission.form_definition.name, form_definition_path(submission.form_definition.uuid), class: "text-primary hover:underline" %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm">
            <% case submission.status %>
            <% when "draft" %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent text-text-muted border border-border">Draft</span>
            <% when "submitted" %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-900/50 text-blue-300 border border-blue-700">Submitted</span>
            <% when "in_review" %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-900/50 text-yellow-300 border border-yellow-700">In Review</span>
            <% when "approved" %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-success/10 text-success border border-success/30">Approved</span>
            <% when "rejected" %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-destructive/10 text-destructive border border-destructive/30">Rejected</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
            <%= submission.submitted_by&.email_address || "Guest" %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-text-muted">
            <%= submission.created_at.strftime("%b %d, %Y %I:%M %p") %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
            <%= link_to "View", form_submission_path(submission.uuid), class: "text-primary hover:underline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @form_submissions.empty? %>
    <div class="px-6 py-12 text-center">
      <p class="text-text-muted">No submissions found.</p>
    </div>
  <% end %>
</div>

<% if @pagy.pages > 1 %>
  <div class="mt-6 flex items-center justify-between">
    <p class="text-sm text-text-muted">
      Showing <%= @pagy.from %>-<%= @pagy.to %> of <%= @pagy.count %> submissions
    </p>
    <nav class="flex items-center space-x-1">
      <% if @pagy.prev %>
        <%= link_to "Previous", form_submissions_path(page: @pagy.prev, form_definition_id: params[:form_definition_id]), class: "px-3 py-2 rounded-lg bg-bg-card border border-border text-sm text-text-muted hover:bg-accent hover:text-text" %>
      <% end %>
      <% if @pagy.next %>
        <%= link_to "Next", form_submissions_path(page: @pagy.next, form_definition_id: params[:form_definition_id]), class: "px-3 py-2 rounded-lg bg-bg-card border border-border text-sm text-text-muted hover:bg-accent hover:text-text" %>
      <% end %>
    </nav>
  </div>
<% end %>
