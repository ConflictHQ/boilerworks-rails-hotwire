<% content_for(:page_title, "Submission ##{@form_submission.uuid[0..7]}") %>

<div class="mb-6">
  <%= link_to form_submissions_path, class: "inline-flex items-center text-sm text-text-muted hover:text-text" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Submissions
  <% end %>
</div>

<div class="bg-bg-card border border-border rounded-lg p-6">
  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-text">Submission</h2>
      <p class="text-sm text-text-muted mt-1">
        Form: <%= link_to @form_submission.form_definition.name, form_definition_path(@form_submission.form_definition.uuid), class: "text-primary hover:underline" %>
      </p>
    </div>
    <div>
      <% case @form_submission.status %>
      <% when "draft" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent text-text-muted border border-border">Draft</span>
      <% when "submitted" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-900/50 text-blue-300 border border-blue-700">Submitted</span>
      <% when "in_review" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-900/50 text-yellow-300 border border-yellow-700">In Review</span>
      <% when "approved" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-success/10 text-success border border-success/30">Approved</span>
      <% when "rejected" %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-destructive/10 text-destructive border border-destructive/30">Rejected</span>
      <% end %>
    </div>
  </div>

  <% if %w[submitted in_review].include?(@form_submission.status) %>
    <div class="flex items-center gap-3 mb-6">
      <%= button_to "Approve", approve_form_submission_path(@form_submission.uuid), method: :post, class: "inline-flex items-center px-4 py-2 bg-success hover:bg-success/80 text-primary-fg rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
      <%= button_to "Reject", reject_form_submission_path(@form_submission.uuid), method: :post, class: "inline-flex items-center px-4 py-2 bg-destructive hover:bg-destructive/80 text-primary-fg rounded-lg text-sm font-medium transition-colors cursor-pointer", form: { data: { turbo_confirm: "Are you sure you want to reject this submission?" } } %>
    </div>
  <% end %>

  <div class="border-t border-border pt-6">
    <h3 class="text-lg font-semibold text-text mb-4">Submitted Data</h3>
    <dl class="space-y-4">
      <% @form_submission.form_definition.field_definitions.each do |field| %>
        <div class="bg-bg rounded-lg p-4">
          <dt class="text-sm font-medium text-text-muted"><%= field["label"] || field["name"] %></dt>
          <dd class="mt-1 text-text">
            <% value = @form_submission.data[field["name"]] %>
            <% if value.is_a?(Array) %>
              <%= value.join(", ") %>
            <% elsif value.present? %>
              <%= value %>
            <% else %>
              <span class="text-text-muted italic">Not provided</span>
            <% end %>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>

  <dl class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6 border-t border-border pt-6">
    <div>
      <dt class="text-sm font-medium text-text-muted">Submitted By</dt>
      <dd class="mt-1 text-text-muted text-sm"><%= @form_submission.submitted_by&.email_address || "Guest" %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-text-muted">Created</dt>
      <dd class="mt-1 text-text-muted text-sm"><%= @form_submission.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-text-muted">Validated</dt>
      <dd class="mt-1 text-text-muted text-sm"><%= @form_submission.validated_at&.strftime("%B %d, %Y at %I:%M %p") || "Not validated" %></dd>
    </div>
  </dl>
</div>
