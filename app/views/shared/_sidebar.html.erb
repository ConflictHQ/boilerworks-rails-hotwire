<aside class="w-64 bg-bg-sidebar border-r border-border min-h-screen flex flex-col">
  <div class="p-6 border-b border-border">
    <a href="<%= root_path %>" class="flex items-center space-x-2">
      <img src="/boilerworks-logo.svg" alt="Boilerworks" class="h-8">
    </a>
  </div>

  <nav class="flex-1 p-4 space-y-1">
    <%= link_to dashboard_path, class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{request.path == dashboard_path ? 'bg-accent text-text' : 'text-text-muted hover:text-text hover:bg-accent'}" do %>
      <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      Dashboard
    <% end %>

    <%= link_to items_path, class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{request.path.start_with?(items_path) ? 'bg-accent text-text' : 'text-text-muted hover:text-text hover:bg-accent'}" do %>
      <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
      </svg>
      Items
    <% end %>

    <%= link_to categories_path, class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{request.path.start_with?(categories_path) ? 'bg-accent text-text' : 'text-text-muted hover:text-text hover:bg-accent'}" do %>
      <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>
      </svg>
      Categories
    <% end %>

    <%= link_to form_definitions_path, class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{request.path.start_with?(form_definitions_path) || request.path.start_with?(form_submissions_path) ? 'bg-accent text-text' : 'text-text-muted hover:text-text hover:bg-accent'}" do %>
      <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      Forms
    <% end %>

    <%= link_to workflow_definitions_path, class: "flex items-center px-3 py-2 rounded-lg text-sm font-medium #{request.path.start_with?(workflow_definitions_path) || request.path.start_with?(workflow_instances_path) ? 'bg-accent text-text' : 'text-text-muted hover:text-text hover:bg-accent'}" do %>
      <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/>
      </svg>
      Workflows
    <% end %>
  </nav>

  <div class="p-4 border-t border-border">
    <div class="flex items-center justify-between">
      <div class="flex items-center min-w-0">
        <div class="w-8 h-8 rounded-full bg-accent flex items-center justify-center text-sm font-medium text-text shrink-0">
          <%= Current.user&.first_name&.first&.upcase || "U" %>
        </div>
        <div class="ml-3 min-w-0">
          <p class="text-sm font-medium text-text truncate">
            <%= Current.user&.first_name %> <%= Current.user&.last_name %>
          </p>
          <p class="text-xs text-text-muted truncate"><%= Current.user&.email_address %></p>
        </div>
      </div>
      <%= button_to session_path, method: :delete, class: "text-text-muted hover:text-text shrink-0 ml-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
      <% end %>
    </div>
  </div>
</aside>
