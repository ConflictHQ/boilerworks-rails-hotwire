<% if flash[:notice] %>
  <div data-controller="flash" class="mb-4">
    <div data-flash-target="message" class="flex items-center justify-between px-4 py-3 bg-green-900/50 border border-green-700 text-green-300 rounded-lg">
      <span><%= flash[:notice] %></span>
      <button type="button" data-action="flash#dismiss" class="text-green-400 hover:text-green-200">&times;</button>
    </div>
  </div>
<% end %>

<% if flash[:alert] %>
  <div data-controller="flash" class="mb-4">
    <div data-flash-target="message" class="flex items-center justify-between px-4 py-3 bg-red-900/50 border border-red-700 text-red-300 rounded-lg">
      <span><%= flash[:alert] %></span>
      <button type="button" data-action="flash#dismiss" class="text-red-400 hover:text-red-200">&times;</button>
    </div>
  </div>
<% end %>
