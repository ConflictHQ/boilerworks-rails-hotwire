<% content_for(:page_title, @category.name) %>

<div class="mb-6">
  <%= link_to categories_path, class: "inline-flex items-center text-sm text-text-muted hover:text-text" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Categories
  <% end %>
</div>

<div class="bg-bg-card border border-border rounded-lg p-6">
  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-text"><%= @category.name %></h2>
      <p class="text-sm text-text-muted mt-1">slug: <%= @category.slug %></p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Edit", edit_category_path(@category.uuid), class: "inline-flex items-center px-4 py-2 bg-bg-input hover:bg-accent text-text rounded-lg text-sm font-medium transition-colors border border-border" %>
      <%= button_to "Delete", category_path(@category.uuid), method: :delete, class: "inline-flex items-center px-4 py-2 bg-destructive hover:bg-destructive/80 text-primary-fg rounded-lg text-sm font-medium transition-colors cursor-pointer", form: { data: { turbo_confirm: "Are you sure you want to delete this category?" } } %>
    </div>
  </div>

  <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <dt class="text-sm font-medium text-text-muted">Parent Category</dt>
      <dd class="mt-1 text-text"><%= @category.parent&.name || "None (top-level)" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-text-muted">Items</dt>
      <dd class="mt-1 text-text"><%= @category.items.count %></dd>
    </div>

    <div class="md:col-span-2">
      <dt class="text-sm font-medium text-text-muted">Description</dt>
      <dd class="mt-1 text-text"><%= @category.description || "No description" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-text-muted">Created</dt>
      <dd class="mt-1 text-text-muted text-sm"><%= @category.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-text-muted">Updated</dt>
      <dd class="mt-1 text-text-muted text-sm"><%= @category.updated_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
    </div>
  </dl>
</div>

<% if @category.children.any? %>
  <div class="mt-6 bg-bg-card border border-border rounded-lg p-6">
    <h3 class="text-lg font-semibold text-text mb-4">Subcategories</h3>
    <div class="space-y-2">
      <% @category.children.each do |child| %>
        <div class="flex items-center justify-between px-4 py-3 bg-accent/50 rounded-lg">
          <%= link_to child.name, category_path(child.uuid), class: "text-primary hover:underline text-sm font-medium" %>
          <span class="text-xs text-text-muted"><%= child.items.count %> items</span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
