<tr id="<%= dom_id(category) %>" class="hover:bg-accent">
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= link_to category.name, category_path(category.uuid), class: "text-primary hover:underline" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= category.slug %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= category.parent&.name || "Top-level" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text">
    <%= category.products.count %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-text-muted">
    <%= category.created_at.strftime("%b %d, %Y") %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to "Edit", edit_category_path(category.uuid), class: "text-primary hover:underline mr-3" %>
    <%= button_to "Delete", category_path(category.uuid), method: :delete, class: "text-destructive hover:underline", form: { data: { turbo_confirm: "Are you sure you want to delete this category?" } } %>
  </td>
</tr>
