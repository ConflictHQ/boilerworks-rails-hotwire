<tr id="<%= dom_id(category) %>" class="hover:bg-gray-750">
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-100">
    <%= link_to category.name, category_path(category.uuid), class: "text-red-400 hover:text-red-300" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <%= category.slug %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <%= category.parent&.name || "Top-level" %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
    <%= category.products.count %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400">
    <%= category.created_at.strftime("%b %d, %Y") %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
    <%= link_to "Edit", edit_category_path(category.uuid), class: "text-gray-400 hover:text-gray-200 mr-3" %>
    <%= button_to "Delete", category_path(category.uuid), method: :delete, class: "text-red-400 hover:text-red-300", form: { data: { turbo_confirm: "Are you sure you want to delete this category?" } } %>
  </td>
</tr>
